<merge_qa_prompt>
  <role>You are sanity-checking merged patch conflicts and downgrade safety.</role>
  <inputs>
    <merged_patch_path>{{MERGED_PATCH_PATH}}</merged_patch_path>
    <merge_report_path>{{MERGE_REPORT_PATH}}</merge_report_path>
  </inputs>
  <rules>
    <rule>Return valid JSON only, matching the provided output schema.</rule>
    <rule>Only propose safe downgrades/removals.</rule>
    <rule>Do not add new edit operations.</rule>
  </rules>
  <output_contract>
    <json_object>{"actions":[{"type":"drop_op","op_index":0},{"type":"downgrade_to_comment","op_index":1,"comment_text":"..."}],"notes":["..."]}</json_object>
  </output_contract>
</merge_qa_prompt>
