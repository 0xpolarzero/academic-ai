<workflow name="fr_copyedit_conservative" version="1">
  <locale>fr-FR</locale>
  <profile>copyedit</profile>
  <pass>primary</pass>
  <policy>
    <meaning_preservation>strict</meaning_preservation>
    <rephrase_if_obscure_only>true</rephrase_if_obscure_only>
    <redo_copyedit_tasks>false</redo_copyedit_tasks>
  </policy>
  <operations>
    <grammar>true</grammar>
    <agreement>true</agreement>
    <spelling>true</spelling>
    <punctuation>true</punctuation>
    <typography>true</typography>
    <style>false</style>
  </operations>
  <constraints>
    <minimal_edits>true</minimal_edits>
    <no_tone_shift>true</no_tone_shift>
    <no_structural_rewrite>true</no_structural_rewrite>
  </constraints>
</workflow>
