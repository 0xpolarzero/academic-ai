{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://academic-ai.local/schemas/chunk_result.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["chunk_id", "suggestions", "ops"],
  "properties": {
    "chunk_id": { "type": "string", "minLength": 1 },
    "suggestions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "ops": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "target", "expected", "quoted_text", "replacement", "new_text", "comment_text"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["add_comment", "replace_range", "insert_at"]
          },
          "target": {
            "type": "object",
            "additionalProperties": false,
            "required": ["part", "para_id", "unit_uid"],
            "properties": {
              "part": { "type": "string", "minLength": 1 },
              "para_id": { "type": "string", "minLength": 1 },
              "unit_uid": { "type": "string", "minLength": 1 }
            }
          },
          "quoted_text": {
            "type": "string",
            "minLength": 20,
            "maxLength": 150,
            "description": "Quote 40-100 total chars with exact target wrapped in [[double brackets]]. Brackets indicate precise span; surrounding context ensures unique matching. Total length must be 40-100 characters."
          },
          "expected": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "snippet": { "type": "string" }
            }
          },
          "replacement": {
            "type": "string"
          },
          "new_text": {
            "type": "string"
          },
          "comment_text": {
            "type": "string"
          }
        }
      }
    }
  }
}
