{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://academic-ai.local/schemas/chunk_qa.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "issues", "fixes"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["ok", "needs_fix"]
    },
    "issues": {
      "type": "array",
      "items": { "type": "string" }
    },
    "fixes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "left_chunk_id", "right_chunk_id", "move_primary_units"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["merge_adjacent", "shift_boundary"]
          },
          "left_chunk_id": { "type": "string", "minLength": 1 },
          "right_chunk_id": { "type": "string", "minLength": 1 },
          "move_primary_units": { "type": "integer" }
        }
      }
    }
  }
}
