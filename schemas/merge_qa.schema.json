{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://academic-ai.local/schemas/merge_qa.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["notes", "actions"],
  "properties": {
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "op_index"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["drop_op", "downgrade_to_comment"]
          },
          "op_index": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
