{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://academic-ai.local/schemas/merge_qa.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["actions"],
  "properties": {
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["drop_op", "downgrade_to_comment"]
          },
          "op_id": { "type": "string" },
          "op_index": { "type": "integer", "minimum": 0 },
          "comment_text": { "type": "string" }
        },
        "allOf": [
          {
            "if": { "properties": { "type": { "const": "drop_op" } }, "required": ["type"] },
            "then": {
              "anyOf": [
                { "required": ["op_id"] },
                { "required": ["op_index"] }
              ]
            }
          },
          {
            "if": { "properties": { "type": { "const": "downgrade_to_comment" } }, "required": ["type"] },
            "then": {
              "required": ["comment_text"],
              "anyOf": [
                { "required": ["op_id"] },
                { "required": ["op_index"] }
              ]
            }
          }
        ]
      }
    }
  }
}
