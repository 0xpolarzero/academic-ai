{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://academic-ai.local/schemas/chunk_result.v1.schema.json",
  "title": "Chunk Result V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "chunk_id",
    "ops"
  ],
  "properties": {
    "schema_version": {
      "const": "chunk_result.v1"
    },
    "chunk_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "ok",
        "needs_review",
        "error"
      ]
    },
    "summary": {
      "type": "string"
    },
    "ops": {
      "type": "array",
      "items": {
        "$ref": "./patch.v1.schema.json#/$defs/patch_operation"
      }
    },
    "patches": {
      "type": "array",
      "items": {
        "$ref": "./patch.v1.schema.json#/$defs/patch_operation"
      },
      "description": "Deprecated alias for ops; retained for backward compatibility."
    },
    "suggestions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "dedup_keys": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "primary_findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "context_notes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "part",
        "para_id"
      ],
      "properties": {
        "part": {
          "type": "string",
          "minLength": 1
        },
        "para_id": {
          "type": "string",
          "minLength": 1
        },
        "unit_uid": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target",
        "message"
      ],
      "properties": {
        "target": {
          "$ref": "#/$defs/target"
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "enum": [
            "low",
            "medium",
            "high"
          ]
        }
      }
    }
  }
}
