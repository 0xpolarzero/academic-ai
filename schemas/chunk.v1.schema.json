{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://academic-ai.local/schemas/chunk.v1.schema.json",
  "title": "Chunk V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "chunk_id",
    "chunk_index",
    "contract",
    "primary_units",
    "context_units_before",
    "context_units_after",
    "metadata"
  ],
  "properties": {
    "schema_version": {
      "const": "chunk.v1"
    },
    "chunk_id": {
      "type": "string",
      "minLength": 1
    },
    "chunk_index": {
      "type": "integer",
      "minimum": 0
    },
    "contract": {
      "$ref": "#/$defs/contract"
    },
    "primary_units": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/primary_unit"
      },
      "minItems": 1
    },
    "context_units_before": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/context_before_unit"
      }
    },
    "context_units_after": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/context_after_unit"
      }
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    }
  },
  "$defs": {
    "contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primary_units_editable",
        "context_units_editable",
        "context_is_read_only",
        "enforcement"
      ],
      "properties": {
        "primary_units_editable": {
          "type": "boolean"
        },
        "context_units_editable": {
          "type": "boolean"
        },
        "context_is_read_only": {
          "type": "boolean"
        },
        "enforcement": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "location": {
      "type": "object",
      "additionalProperties": true
    },
    "heading_path": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "chunk_unit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "part",
        "part_kind",
        "part_name",
        "para_id",
        "unit_uid",
        "accepted_text",
        "heading_path",
        "order_index",
        "location",
        "role",
        "editable",
        "token_estimate"
      ],
      "properties": {
        "part": {
          "type": "string",
          "minLength": 1
        },
        "part_kind": {
          "type": "string",
          "minLength": 1
        },
        "part_name": {
          "type": "string",
          "minLength": 1
        },
        "para_id": {
          "type": "string",
          "minLength": 1
        },
        "unit_uid": {
          "type": "string",
          "minLength": 1
        },
        "accepted_text": {
          "type": "string"
        },
        "heading_path": {
          "$ref": "#/$defs/heading_path"
        },
        "order_index": {
          "type": "integer",
          "minimum": 0
        },
        "location": {
          "$ref": "#/$defs/location"
        },
        "role": {
          "enum": [
            "primary",
            "context_before",
            "context_after"
          ]
        },
        "editable": {
          "type": "boolean"
        },
        "token_estimate": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "primary_unit": {
      "allOf": [
        {
          "$ref": "#/$defs/chunk_unit"
        },
        {
          "properties": {
            "role": {
              "const": "primary"
            },
            "editable": {
              "const": true
            }
          }
        }
      ]
    },
    "context_before_unit": {
      "allOf": [
        {
          "$ref": "#/$defs/chunk_unit"
        },
        {
          "properties": {
            "role": {
              "const": "context_before"
            },
            "editable": {
              "const": false
            }
          }
        }
      ]
    },
    "context_after_unit": {
      "allOf": [
        {
          "$ref": "#/$defs/chunk_unit"
        },
        {
          "properties": {
            "role": {
              "const": "context_after"
            },
            "editable": {
              "const": false
            }
          }
        }
      ]
    },
    "source_span": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "start_linear_index",
        "end_linear_index",
        "start_order_index",
        "end_order_index",
        "primary_unit_count",
        "context_before_count",
        "context_after_count",
        "requested_overlap_before",
        "requested_overlap_after",
        "context_trimmed_for_budget"
      ],
      "properties": {
        "start_linear_index": {
          "type": "integer",
          "minimum": 0
        },
        "end_linear_index": {
          "type": "integer",
          "minimum": 0
        },
        "start_order_index": {
          "type": "integer",
          "minimum": 0
        },
        "end_order_index": {
          "type": "integer",
          "minimum": 0
        },
        "primary_unit_count": {
          "type": "integer",
          "minimum": 1
        },
        "context_before_count": {
          "type": "integer",
          "minimum": 0
        },
        "context_after_count": {
          "type": "integer",
          "minimum": 0
        },
        "requested_overlap_before": {
          "type": "integer",
          "minimum": 0
        },
        "requested_overlap_after": {
          "type": "integer",
          "minimum": 0
        },
        "context_trimmed_for_budget": {
          "type": "boolean"
        }
      }
    },
    "token_estimates": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primary_tokens",
        "context_before_tokens",
        "context_after_tokens",
        "total_tokens",
        "target_tokens",
        "hard_max_tokens",
        "is_within_hard_max",
        "allowed_overflow"
      ],
      "properties": {
        "primary_tokens": {
          "type": "integer",
          "minimum": 1
        },
        "context_before_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "context_after_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "total_tokens": {
          "type": "integer",
          "minimum": 1
        },
        "target_tokens": {
          "type": "integer",
          "minimum": 1
        },
        "hard_max_tokens": {
          "type": "integer",
          "minimum": 1
        },
        "is_within_hard_max": {
          "type": "boolean"
        },
        "allowed_overflow": {
          "type": "boolean"
        },
        "overflow_reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "heading_path",
        "source_span",
        "token_estimates"
      ],
      "properties": {
        "heading_path": {
          "$ref": "#/$defs/heading_path"
        },
        "source_span": {
          "$ref": "#/$defs/source_span"
        },
        "token_estimates": {
          "$ref": "#/$defs/token_estimates"
        }
      }
    }
  }
}
